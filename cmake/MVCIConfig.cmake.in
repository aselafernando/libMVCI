@PACKAGE_INIT@

# Re-discover the runtime dependencies the imported target links against.
include(CMakeFindDependencyMacro)
if(NOT WIN32 AND NOT APPLE)
    find_dependency(OpenSSL)      # libcrypto for DES on Linux/Unix
endif()
if(NOT WIN32)
    set(THREADS_PREFER_PTHREAD_FLAG ON)
    find_dependency(Threads)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/MVCITargets.cmake")

check_required_components(MVCI)
