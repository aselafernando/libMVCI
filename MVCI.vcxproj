<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|Win32">
      <Configuration>Debug</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{8E9C1B2A-4D3F-4A1E-9C7B-1A2B3C4D5E6F}</ProjectGuid>
    <RootNamespace>MVCI</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <PlatformToolset>v145</PlatformToolset>
    <CharacterSet>NotSet</CharacterSet>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
    <WholeProgramOptimization Condition="'$(Configuration)'=='Release'">true</WholeProgramOptimization>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <!-- Output MVCI32.dll for Win32, MVCI64.dll for x64. -->
  <PropertyGroup>
    <TargetName Condition="'$(Platform)'=='Win32'">MVCI32</TargetName>
    <TargetName Condition="'$(Platform)'=='x64'">MVCI64</TargetName>
    <OutDir>$(SolutionDir)lib\$(Configuration)\</OutDir>
    <IntDir>$(SolutionDir)obj\$(Platform)\$(Configuration)\</IntDir>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <CompileAs>CompileAsC</CompileAs>
      <LanguageStandard_C>stdc11</LanguageStandard_C>
      <WarningLevel>Level3</WarningLevel>
      <Optimization Condition="'$(Configuration)'=='Release'">MaxSpeed</Optimization>
      <Optimization Condition="'$(Configuration)'=='Debug'">Disabled</Optimization>
      <PreprocessorDefinitions>MVCI_BUILDING_DLL;_CRT_SECURE_NO_WARNINGS;WIN32_LEAN_AND_MEAN;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(SolutionDir)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!-- ftd2xx.dll is loaded at runtime (LoadLibrary), so no FTDI SDK/lib is
           needed to build — only bcrypt.lib (a standard Windows system lib). -->
    </ClCompile>
    <Link>
      <ModuleDefinitionFile>src\mvci.def</ModuleDefinitionFile>
      <AdditionalDependencies>bcrypt.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="src\passthru.c" />
    <ClCompile Include="src\serial.c" />
    <ClCompile Include="src\io.c" />
    <ClCompile Include="src\des.c" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="include\mvci\j2534.h" />
    <ClInclude Include="include\mvci\serial.h" />
    <ClInclude Include="src\io.h" />
    <ClInclude Include="src\compat.h" />
  </ItemGroup>
  <ItemGroup>
    <None Include="src\mvci.def" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>